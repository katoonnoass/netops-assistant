# ═══════════════════════════════════════════════════════════
# NetOps Assistant — Produção (exemplo seguro)
# ═══════════════════════════════════════════════════════════
# ATENÇÃO: NUNCA commitar este arquivo com senhas reais.
# Use secrets manager ou env vars do Docker em produção.
# ═══════════════════════════════════════════════════════════

# ─── DJANGO ────────────────────────────────────────────

# Gere uma chave forte: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-use-a-long-random-secret

# False em produção. True apenas para debug local.
DJANGO_DEBUG=False

# Hosts/IPs permitidos (separados por vírgula)
DJANGO_ALLOWED_HOSTS=netops.seudominio.local,IP_DO_SERVIDOR

# Origens confiáveis para CSRF (separadas por vírgula)
DJANGO_CSRF_TRUSTED_ORIGINS=https://netops.seudominio.local,http://IP_DO_SERVIDOR

# ─── SSL / HTTPS ──────────────────────────────────────
# Use True e HSTS > 0 apenas quando HTTPS estiver funcionando.

# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True

# ─── DATABASE ─────────────────────────────────────────
DATABASE_URL=postgres://netops:change-me-strong-password@db:5432/netops_assistant

# ─── POSTGRES (usado pelo container db e entrypoint) ───
POSTGRES_DB=netops_assistant
POSTGRES_USER=netops
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── BACKUP ───────────────────────────────────────────
BACKUP_RETENTION_DAYS=14
