# NetOps Assistant - Configuração de Ambiente
# Copie este arquivo como .env e ajuste os valores

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Banco de Dados (SQLite para desenvolvimento)
# Para PostgreSQL em produção, descomente e configure:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=netops_assistant
# DB_USER=netops
# DB_PASSWORD=suasenha
# DB_HOST=localhost
# DB_PORT=5432
