# ═══════════════════════════════════════════════════════════
# NetOps Assistant — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════
# ATENÇÃO: NUNCA commitar este arquivo com senhas reais.
# Use secrets manager ou env vars do Docker em produção.
# ═══════════════════════════════════════════════════════════

# ─── DJANGO ────────────────────────────────────────────

# Gere uma chave forte: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret-key

# False em produção. True apenas para debug local.
DJANGO_DEBUG=False

# Hosts/IPs permitidos (separados por vírgula)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,seu-dominio.local

# Origens confiáveis para CSRF (separadas por vírgula)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1,https://seu-dominio.local

# SSL — ative apenas se tiver HTTPS configurado
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# ─── DATABASE (PostgreSQL via DATABASE_URL) ──────────
# Para SQLite local, remova DATABASE_URL e deixe comentado.
DATABASE_URL=postgres://netops:netops_secret@db:5432/netops_assistant

# ─── DATABASE (alternativa usando variáveis individuais) ──
# DB_ENGINE=postgresql
# DB_NAME=netops_assistant
# DB_USER=netops
# DB_PASSWORD=netops_secret
# DB_HOST=db
# DB_PORT=5432

# ─── POSTGRES (usado pelo container db e entrypoint) ───
POSTGRES_DB=netops_assistant
POSTGRES_USER=netops
# Altere esta senha para algo seguro
POSTGRES_PASSWORD=netops_secret
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── PATHS (opcional — padrão já funcionam) ──────────
# DJANGO_STATIC_ROOT=/app/staticfiles
# DJANGO_MEDIA_ROOT=/app/media

# ─── BACKUP (opcional) ────────────────────────────────
# BACKUP_RETENTION_DAYS=7
